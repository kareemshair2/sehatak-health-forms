<?xml version="1.0" encoding="UTF-8"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:o="urn:schemas-microsoft-com:office:office"
 xmlns:x="urn:schemas-microsoft-com:office:excel"
 xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:html="http://www.w3.org/TR/REC-html40">
 <Styles>
  <Style ss:ID="header">
   <Font ss:Bold="1" ss:Color="#FFFFFF" ss:Size="12"/>
   <Interior ss:Color="#0f766e" ss:Pattern="Solid"/>
   <Alignment ss:Horizontal="Center" ss:Vertical="Center"/>
  </Style>
  <Style ss:ID="success">
   <Font ss:Color="#006100"/>
   <Interior ss:Color="#C6EFCE" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="fail">
   <Font ss:Color="#9C0006"/>
   <Interior ss:Color="#FFC7CE" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="warn">
   <Font ss:Color="#9C6500"/>
   <Interior ss:Color="#FFEB9C" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="normal">
   <Alignment ss:Vertical="Top"/>
  </Style>
  <Style ss:ID="wrap">
   <Alignment ss:Vertical="Top" ss:WrapText="1"/>
  </Style>
 </Styles>

 <Worksheet ss:Name="نتائج الاختبارات">
  <Table>
   <Column ss:Width="35"/>
   <Column ss:Width="180"/>
   <Column ss:Width="100"/>
   <Column ss:Width="150"/>
   <Column ss:Width="80"/>
   <Column ss:Width="400"/>
   <Column ss:Width="200"/>
   <Row ss:Height="25">
    <Cell ss:StyleID="header"><Data ss:Type="String">#</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">الاستمارة</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">Action</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">البيانات المرسلة</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">النتيجة</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">رسالة الرد</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">ملاحظات</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">المساعدات الطبية</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">submit</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">patient_name, national_id, phone_number, center, medicines (JSON), prescription_photo (base64), id_photo (base64)</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">نجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تم تسجيل الحالة بنجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">صيغة: x-www-form-urlencoded. يتضمن فحص تكرار الرقم القومي (checkNID). صورتان اختياريتان (روشتة + بطاقة) كـ base64.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">التحويلات الطبية</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">referral</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">patient_name, patient_age, patient_gender, patient_phone, national_id, patient_center, patient_address, referral_date, referral_type, referral_image (base64), notes, staff_name + حقول ديناميكية حسب النوع (doctor, lab, radiology, glasses, physio)</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">نجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تم تسجيل التحويل بنجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">صيغة: JSON. يدعم 5 أنواع تحويل (دكتور/معمل/أشعة/نظارة/علاج طبيعي). صورة تحويل واحدة اختيارية كـ base64.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">حصر الأدوية</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">hser_edwia</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">date, sec, tab (JSON array: name, ava, typ, do, quan, date_kw6pm91, takhassos)</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">نجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تم تسجيل 1 دواء</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">صيغة: x-www-form-urlencoded. لا يحتوي صور. يدخل أدوية متعددة (كل دواء صف منفصل في الشيت).</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">4</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">أدوية القوافل</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">adwyt_alqawafel</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">date, center, tab (JSON array: _=name, __001=conc, __002=exp, __003=active, __004=type, __005=unit, __006=qty, __007=spec)</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">نجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تم تسجيل 1 دواء</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">صيغة: x-www-form-urlencoded. لا يحتوي صور. أسماء الحقول مرمزة (_, __001...__007) لتقليل حجم الـ payload.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">5</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">صرف أدوية القوافل</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">sarf_alqawafel</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">center, caravan_date, prescription_group (array: doctor_name, doctor_specialty, prescription_photo base64, medicine_group array)</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">نجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تم تسجيل 1 روشتة</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">صيغة: JSON. يدخل روشتات متعددة لكل منها أدوية متعددة وصورة روشتة. تم إصلاح headers (إزالة mode:cors, cache, charset) في commit a2a471c.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">6</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">نتائج القوافل</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">nata2_alqawafel</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">center, total_checkups, total_labs, other_interventions, other_interventions_count, specialties (array: specialty, doctor_name, spec_checkups, time_spent)</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">نجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تم تسجيل نتائج القافلة بنجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">صيغة: JSON. لا يحتوي صور. التخصصات تُخزن كـ JSON array.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">7</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">التعاقدات الطبية</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">taaqodat</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">entity_type, facility_name, contract_text, contract_photo (base64), contractor_name, volunteer_number, name_contractor, job_title, facility_phone, detailed_address, location, center, notes</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">نجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تم تسجيل التعاقد بنجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">صيغة: JSON. صورة عقد اختيارية كـ base64.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">8</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">مصروفات الحالات</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">masroufat</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">patient_name, patient_code, integer_wa4xt75 (amount), center, prescription_photo (base64), medications_group (array: med_name, med_qty, med_source)</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">نجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تم تسجيل المصروفات بنجاح</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">صيغة: JSON. صورة روشتة اختيارية كـ base64. حقل المبلغ باسم integer_wa4xt75 (encoded name).</Data></Cell>
   </Row>
  </Table>
 </Worksheet>

 <Worksheet ss:Name="الاستعلامات">
  <Table>
   <Column ss:Width="35"/>
   <Column ss:Width="200"/>
   <Column ss:Width="150"/>
   <Column ss:Width="400"/>
   <Column ss:Width="300"/>
   <Row ss:Height="25">
    <Cell ss:StyleID="header"><Data ss:Type="String">#</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">النظام</Data></Cell>
    <Cell ss:Type="String" ss:StyleID="header">مصدر البيانات</Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">طريقة الاستعلام</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">النتيجة</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">استعلامات الأدوية (look)</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">Google Sheets: 1HddJ7VRSfL6iH1JtiSFx4SR09VfSaMdbUgZGo-4AqHE → tab "look"</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">gviz/tq (Google Visualization API)، بحث بـ 2 حروف أو أكثر</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل - الشيت عام وقابل للقراءة</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">استعلامات القوافل (convoy)</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">Google Sheets: 1HddJ7VRSfL6iH1JtiSFx4SR09VfSaMdbUgZGo-4AqHE → tab "convoy"</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">gviz/tq (Google Visualization API)، بحث بـ 4 حروف أو أكثر</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل - الشيت عام وقابل للقراءة</Data></Cell>
   </Row>
  </Table>
 </Worksheet>

 <Worksheet ss:Name="الفيتشرز">
  <Table>
   <Column ss:Width="35"/>
   <Column ss:Width="200"/>
   <Column ss:Width="150"/>
   <Column ss:Width="400"/>
   <Row ss:Height="25">
    <Cell ss:StyleID="header"><Data ss:Type="String">#</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">الميزة</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">الحالة</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">ملاحظات</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">إرسال البيانات إلى Google Sheets</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">جميع 8 استمارات ترسل بنجاح باستخدام JSON أو x-www-form-urlencoded حسب كل استمارة</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">رفع الصور (base64 → Drive)</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">5 استمارات تدعم الصور (مساعدات طبية، تحويلات، صرف أدوية، تعاقدات، مصروفات). الصور تُضغط تلقائياً لأقل من 1200px.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">CSV تصدير</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">downloadCSVTemplate() في offline-utils.js. تم إصلاح خطأ استدعاء الدالة (كانت _downloadCSVTemplate).</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">4</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">Excel تصدير</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">downloadXLS() في offline-utils.js. يستخدم HTML table → .xls trick. تمت الإضافة في commit 31ae19b.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">5</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">حفظ محلي (Local Save)</Data></Cell>
    <Cell ss:StyleID="warn"><Data ss:Type="String">بحاجة اختبار</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">يستخدم localStorage لتخزين البيانات محلياً. يحتاج اختبار يدوي في المتصفح.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">6</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">بحث وتصفية (الاستمارات)</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">5 تبويبات تصنيف (كشف طبي، تحويل، صيدلية، قافلة، إحصائيات) + مربع بحث نصي</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">7</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">Dark Mode</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">موجود في index.html والاستمارات.html فقط. يحفظ الحالة في localStorage.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">8</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">Toast Notifications</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">موجود في index.html والاستمارات.html. يدعم success/error/info مع slide animation.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">9</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">Skeleton Loading</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">6 كروت skeleton مع pulse animation في الاستمارات.html</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">10</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">فحص تكرار الرقم القومي</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">checkNID عبر doGet. يفحص عمود C في شيت المساعدات الطبية.</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">11</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">قوائم الأدوية الديناميكية</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">إضافة/حذف أدوية ديناميكياً في استمارات صرف أدوية، مساعدات طبية، مصروفات</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">12</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">إضافة روشتات متعددة</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">خاص باستمارة صرف أدوية القوافل - إضافة/حذف روشتات متعددة مع صور وأطباء وأدوية</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">13</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">ضغط الصور تلقائياً</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">الصور الأكبر من 1MB تُضغط إلى JPEG quality 0.7، حد أقصى 1200px</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">14</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">إعادة المحاولة (Retry)</Data></Cell>
    <Cell ss:StyleID="success"><Data ss:Type="String">✓ يعمل</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">كل استمارة تعيد المحاولة حتى 3 مرات في حالة فشل الإرسال</Data></Cell>
   </Row>
  </Table>
 </Worksheet>

 <Worksheet ss:Name="الإصلاحات">
  <Table>
   <Column ss:Width="35"/>
   <Column ss:Width="100"/>
   <Column ss:Width="250"/>
   <Column ss:Width="300"/>
   <Column ss:Width="200"/>
   <Row ss:Height="25">
    <Cell ss:StyleID="header"><Data ss:Type="String">#</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">التاريخ</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">الخطأ</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">الإصلاح</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">Commit</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">19/06/2026</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تشفير عربي مزدوج (double-encoding) في 8 ملفات HTML</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تحويل الملفات UTF-8 → Windows-1252 → UTF-8 لإصلاح التلف</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">198574b</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">19/06/2026</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">استدعاء دالة غير موجودة (_downloadCSVTemplate)</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تصحيح الاسم إلى downloadCSVTemplate في 5 ملفات</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">31ae19b</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">19/06/2026</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">عدم وجود وظيفة تصدير Excel</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">إضافة downloadXLS() و exportFormXLS() في offline-utils.js + زر Excel في شريط الأدوات</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">31ae19b</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">4</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">19/06/2026</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">إخفاء أزرار الأدوات بتسميات غير واضحة</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تغيير تسميات الأزرار من "تصدير CSV" → "CSV"، إضافة "Excel"</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">31ae19b</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">5</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">19/06/2026</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">عدم تطابق أسماء الملفات مع Code.gs - بعض الاستمارات تستخدم أسماء ملفات لا تتطابق مع اسمها الفعلي في موقع GitHub Pages</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تم تحديث أسماء الملفات في الاستمارات.html لتتوافق: أدوية_القوافل, حصر_الأدوية, نتائج_القوافل, التحويلات_الطبية, التعاقدات_الطبية, المساعدات_الطبية, صرف_أدوية_القوافل, مصروفات_الحالات</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">-</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="normal"><Data ss:Type="Number">6</Data></Cell>
    <Cell ss:StyleID="normal"><Data ss:Type="String">19/06/2026</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">إخفاء صرف الأدوية: headers معقدة (mode:cors, cache, charset) قد تسبب CORS preflight failure</Data></Cell>
    <Cell ss:StyleID="wrap"><Data ss:Type="String">تبسيط headers إلى `{'Content-Type': 'application/json'}` + إضافة console.log للتصحيح</Data></Cell>
